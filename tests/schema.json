{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Appointment API Response",
  "type": "object",
  "required": ["success"],
  "properties": {
    "success": {
      "type": "boolean"
    },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "service", "date", "status"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "service": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "confirmed", "cancelled"]
          },
          "created_at": {
            "type": "string"
          }
        }
      }
    },
    "message": {
      "type": "string"
    },
    "error": {
      "type": "string"
    }
  }
}